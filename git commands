git config user.name 'yourname' #for local folders
git config user.email 'youremail'

git config --global user.name 'yourname' #for global use
git clone 'link'
git fetch
git commit -m 'message'

git commit -m 'heading' -m 'body'
git commit -m 'title' -m 'body'
git commit -m 'heading' -m 'body' -m 'ShorExplain'

# git commit -m 'heading' -m 'body' is only work in cli (terminal), it cannot be used in gui code editer like vs code extensions.

git commit -a -m 'message'
git commit -a -m 'heading' -m 'body'